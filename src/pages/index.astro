---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../utils/posts';
import { SITE, AUTHOR, LATEST_COUNT } from '../config';

// Homepage leads with the most recent writing (Simon-Willison-style recency,
// not a hand-curated best-of). Newest first, capped at the latest few.
const latestPosts = (await getPublishedPosts())
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, LATEST_COUNT);

// Structured data: establish the site as a WebSite entity, published by the
// same Person (AUTHOR.id) defined on /about, so every page resolves to one
// author identity for search engines and AI answer engines.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': SITE.id,
  url: `${SITE.url}/`,
  name: SITE.title,
  description: SITE.description,
  inLanguage: 'en-US',
  publisher: { '@id': AUTHOR.id },
};
---

<BaseLayout
  title="Aaron Roy"
  description="Observations, learnings, and tutorials from building startups, working with AI agents, and riding bikes."
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <div class="max-w-3xl mx-auto px-6 py-16">
    <!-- Intro Section -->
    <section class="mb-20">
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">
        Hi there, I'm Aaron Roy 👋
      </h1>
    </section>

    <!-- Latest Section -->
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-semibold">Latest</h2>
        <a href="/writing/" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">
          View all →
        </a>
      </div>

      <div class="space-y-10">
        {latestPosts.map((post) => (
          <article class="group">
            <a href={`/${post.slug}/`} class="block">
              <h3 class="text-xl font-semibold mb-2 group-hover:text-blue-600 transition-colors">
                {post.data.title}
              </h3>
              <div class="flex items-center gap-3 text-sm text-gray-600 mb-3">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-us', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                {post.data.categories && post.data.categories.length > 0 && (
                  <>
                    <span>•</span>
                    <span>{post.data.categories[0]}</span>
                  </>
                )}
              </div>
              <p class="text-gray-600 leading-relaxed">
                {post.data.description}
              </p>
            </a>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
