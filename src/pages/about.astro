---
import BaseLayout from '../layouts/BaseLayout.astro';
import { AUTHOR, SITE } from '../config';

// Structured data: identify Aaron as a machine-readable entity so search
// engines (Knowledge Graph) and AI answer engines can attribute and cite him.
// The Person carries a stable @id (AUTHOR.id) reused across the site.
const profileSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: `${SITE.url}/about/`,
  name: 'About Aaron Roy',
  mainEntity: {
    '@type': 'Person',
    '@id': AUTHOR.id,
    name: AUTHOR.name,
    url: SITE.url,
    image: `${SITE.url}${AUTHOR.image}`,
    email: `mailto:${AUTHOR.email}`,
    jobTitle: AUTHOR.jobTitle,
    description: AUTHOR.bio,
    worksFor: AUTHOR.affiliations.map((org) => ({
      '@type': 'Organization',
      name: org.name,
      ...('url' in org ? { url: org.url } : {}),
    })),
    alumniOf: {
      '@type': 'CollegeOrUniversity',
      name: AUTHOR.alumniOf,
    },
    homeLocation: {
      '@type': 'Place',
      name: AUTHOR.location,
    },
    knowsAbout: AUTHOR.knowsAbout,
    sameAs: [
      AUTHOR.social.twitter,
      AUTHOR.social.linkedin,
      AUTHOR.social.github,
    ],
  },
};
---

<BaseLayout title="About" description="Learn more about Aaron Roy">
  <script type="application/ld+json" set:html={JSON.stringify(profileSchema)} />
  <div class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-12">About Me</h1>

    <div class="prose prose-lg max-w-none
      prose-p:leading-relaxed prose-p:mb-6
      prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline">

      <p>
        Hey, I'm Aaron 👋
      </p>
      <p>
        I love tinkering. Some of my recent projects include <a href="https://apps.apple.com/us/app/glutenornot/id6758594582" target="_blank" rel="noopener noreferrer">GlutenOrNot</a> (a free ingredient-scanner app for celiacs) and an <a href="https://github.com/amr05008/personal-context" target="_blank" rel="noopener noreferrer">open-source MCP server</a> for giving agents personal context.
      </p>
      <p>
        My other passions are <a href="/category/bikes/">riding bikes</a>, diving into cybersecurity rabbit holes, and hanging with my family. I use this site to share what I'm working on and whatever else I find interesting.
      </p>
      <p>
        Professionally, I'm currently Product Director at Manychat, where I'm building <a href="https://manychat.com/brands" target="_blank" rel="noopener noreferrer">Manychat for Brands</a>.
      </p>
      <p>Other work and projects:</p>
      <ul>
        <li>Co-founded <a href="https://wami.io/" target="_blank" rel="noopener noreferrer">Wami</a>, a robotic handwritten notes company that produces handwritten notes at scale.</li>
        <li>Head of Product at <a href="https://www.teachable.com/" target="_blank" rel="noopener noreferrer">Teachable</a></li>
        <li>Led product at Bond through its acquisition by Newell Brands</li>
        <li>Part of the founding team at <a href="https://www.3dprinteros.com/" target="_blank" rel="noopener noreferrer">3DPrinterOS</a>, the first cloud operating system for 3D printing.</li>
        <li>Started pedicab companies in <a href="https://www.needaridenola.com/" target="_blank" rel="noopener noreferrer">New Orleans</a> and Miami.</li>
      </ul>

      <h2 class="text-2xl font-semibold mt-12 mb-6">Get in touch</h2>

      <p>
        Please send me an <a href="mailto:aaron@aaronroy.com?subject=Hello from the blog&body=Hi%20there!">email</a> or reach out to me on <a href="https://linkedin.com/in/aaronmichaelroy" target="_blank" rel="noopener noreferrer">LinkedIn</a>.
      </p>

          <h2 class="text-2xl font-semibold mt-12 mb-6">About this site</h2>

      <p>
        This site was custom built using <a href="https://www.claude.com/product/claude-code" target="_blank" rel="noopener noreferrer">Claude Code</a>. The source code can be found on Github at <a href="https://github.com/amr05008/aaronroy.com" target="_blank" rel="noopener noreferrer">amr05008/aaronroy.com</a>

      </p>
  </div>
</BaseLayout>
