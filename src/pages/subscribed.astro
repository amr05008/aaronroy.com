---
// Landing page for Buttondown's "after subscribing" redirect: the reader has
// submitted the email form but hasn't clicked the confirmation link yet.
// Not linked from anywhere on the site — reached only via the redirect.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Check your email"
  description="One more step to confirm email notifications from aaronroy.com."
  noindex
>
  <div class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-3xl font-bold tracking-tight mb-6">One more step</h1>
    <p class="text-lg text-gray-700 leading-relaxed mb-4">
      I just sent you a confirmation email. Check your email and click the link inside,
      nothing lands in your inbox until you do.
    </p>
    <p class="text-lg text-gray-700 leading-relaxed">
      In the meantime, head <a href="/" class="text-blue-600 hover:underline">back to the homepage</a>
      or keep <a href="/writing/" class="text-blue-600 hover:underline">reading</a>.
    </p>
  </div>
</BaseLayout>
